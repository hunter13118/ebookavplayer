# Copy to fly-secrets.env (gitignored), fill in values, then:
#   fly secrets import < deploy/fly-secrets.env
#
# Do NOT commit fly-secrets.env.

# Required — extraction + images
GEMINI_API_KEY=

# Shared with portfolio Worker (must match wrangler secret QUEUE_WEBHOOK_SECRET)
QUEUE_WEBHOOK_SECRET=

# Cloudflare Workers AI (images + extract fallback)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2 pack mirror (same bucket as portfolio Worker VAE_PACKS)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vae-packs

# Optional freemium fallbacks
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# POLLINATIONS_TOKEN=
# HF_TOKEN=
