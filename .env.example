# ---- Gemini (single mega-pass + image gen). Free tier via Google AI Studio. ----
GEMINI_API_KEY=
# Text mega-pass. Gemini 3.5 is current (2026); gemini-2.5-flash stays valid and
# is reliable for JSON mode. Try gemini-3.5-flash / gemini-flash-latest to upgrade.
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated fallback chains (tried in order on rate limit / quota errors).
GEMINI_TEXT_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash
GEMINI_IMAGE_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image,gemini-3-pro-image
# Retries per model on 429 / rate-limit before advancing the chain.
GEMINI_RETRY_COUNT=2
GEMINI_RETRY_BACKOFF_SEC=3
# Local SD via this repo's own scripts/local-image-server (SDXL-Turbo, no
# cloud key, no dependency on another project). Base URL only — the worker
# appends /generate itself. Auto-detects CUDA > Apple Metal (MPS) > CPU;
# see docs/LOCAL_LLM_EXTRACTION.md for setup and the same reasoning applied
# to local LLM extraction via Ollama.
LOCAL_IMAGE_URL=http://127.0.0.1:7860
LOCAL_IMAGE_TIMEOUT=300
# LOCAL_IMAGE_DEVICE=          # cuda | mps | cpu — override auto-detect if it guesses wrong
# sdxl-turbo | animagine-xl | sd15-anime-lcm — the server's own default is
# sdxl-turbo, which has NO IP-Adapter (reference-image) support at all
# (guidance_scale=0.0 strips the steering mechanism it needs). Set this to
# animagine-xl or sd15-anime-lcm to actually use character reference images
# — see docs/LOCAL_IMAGE_GEN.md.
LOCAL_IMAGE_MODEL=animagine-xl
# SAVE_RETRY_ATTEMPTS=1        # server-side: save each retry attempt's raw
#   generation to scripts/local-image-server/debug/attempts/ (gitignored) so a
#   failing character can be inspected frame-by-frame. On by default; set 0 to
#   disable the disk writes. See docs/LOCAL_IMAGE_GEN.md "character sheet".

# Free image APIs (server-side only — see IMAGE AND VOICE HANDOFF/)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_EXTRACT_MODEL=@cf/meta/llama-3.1-8b-instruct
# POLLINATIONS_TOKEN=          # sk_... from enter.pollinations.ai (Bearer auth)
# POLLINATIONS_I2I_MODEL=kontext   # i2i refs: kontext, seedream, klein (needs pollen on gen.pollinations.ai)
# PUBLIC_MEDIA_ORIGIN=https://hunterthemilkman.com/projects/ebookavplayer/api
#   Public base so Pollinations can fetch /media/ reference URLs for image-to-image.
# VAE_EPUB_MAX_IMAGES=0        # 0 = extract all EPUB plates; set N to cap ingest illustrations.
# POLLINATIONS_IMAGE_MODEL=flux   # authed tier (costs pollen when balance > 0)
# POLLINATIONS_FREE_MODEL=flux      # 0-pollen fallback: unauthenticated flux
# HF_TOKEN=                    # Inference Providers (FLUX.1-schnell via hf-inference router)
# FAL_KEY=                     # Optional: direct fal.ai billing when HF monthly credits are depleted
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_IMAGE_PROVIDERS=hf-inference
# DISABLE_FREEMIUM_IMAGE=0

# Local LLM extraction via Ollama (`ollama serve` on your own machine — no API
# key, no rate limit, fully offline). With `wrangler dev` on the same box as
# Ollama, leave this as localhost. For a deployed Worker (`wrangler deploy`),
# point this at a Cloudflare Tunnel hostname routed to your machine instead —
# see docs/LOCAL_LLM_EXTRACTION.md's "Reaching local Ollama/MLX from a
# deployed Worker" section — and set it via `wrangler secret put`, not here.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_7B=qwen2.5:7b
# OLLAMA_MODEL_20B=gpt-oss:20b
# OLLAMA_MODEL_30B=qwen3:30b-a3b
# OLLAMA_MODEL_14B=qwen2.5:14b
# Vision-capable model used by illustration-character-match.js to actually
# look at a plate's pixels (not just surrounding text) when deciding which
# character it depicts. gemma3 is natively multimodal — no separate vision
# model pull needed if you already have a gemma3 tag (`ollama list`).
# OLLAMA_MODEL_VISION=gemma3:27b
# Context window sent to Ollama per request. Auto-computed by default (chunk
# budget above * 8 — the same ratio the old fixed 16384/2000 pairing already
# proved safe at), floored at 4096 so it never goes small enough to risk
# truncating a dialogue-dense chunk's output mid-JSON. A smaller window means
# less KV-cache for Ollama to compute attention over per generation step —
# real overhead independent of model choice. Override only if the computed
# value turns out wrong for a specific book.
# OLLAMA_NUM_CTX=6400

# MLX (Apple Silicon only, experimental) — additive alternative to Ollama for
# the ollama-30b model specifically, only worth it once VAE_EXTRACT_CONCURRENCY
# is deliberately raised above 1 (Ollama wins on solo speed everywhere else).
# Needs a separate `pip install mlx-lm` venv + `mlx_lm.server` running, not a
# replacement for Ollama. See docs/LOCAL_LLM_EXTRACTION.md.
# MLX_BASE_URL=http://localhost:8081
# MLX_MODEL_30B=mlx-community/Qwen3-30B-A3B-4bit

# Cloudflare Access service-token headers — required only when OLLAMA_BASE_URL/
# MLX_BASE_URL above point at a Cloudflare Tunnel hostname instead of
# localhost (a deployed Worker reaching back to your machine). Generate a
# Service Token under Zero Trust -> Access -> Service Tokens, gated by a
# Service Auth policy on the tunnel's Access application. No effect against a
# bare localhost target — Ollama/MLX just ignore the extra headers.
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Free LLM extract APIs (fallback when Gemini quota exhausted — freemiumExtract.js)
# CEREBRAS_API_KEY=
# CEREBRAS_EXTRACT_MODEL=gpt-oss-120b
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# DISABLE_FREEMIUM_EXTRACT=0
# EXTRACT_FORCE_FREEMIUM=0
# Max tokens per extract chunk (default 2000, applies to every provider —
# local and cloud alike). Lower it for local Ollama/MLX to get more, smaller,
# faster round-trips per chapter instead of one slow call sitting silent for
# many minutes with no visible progress (try 600-1000). Character AND scene
# continuity across chunks are both handled regardless of chunk count — see
# docs/LOCAL_LLM_EXTRACTION.md's "Chunk size vs. progress granularity vs.
# scene continuity" section for how (best-effort: depends on the model
# actually flagging a mid-scene cutoff, falls back to plain concatenation
# when it doesn't). Raise this instead for fast cloud providers to cut
# round-trip count if you're not hitting per-request size limits.
# EXTRACT_CHUNK_MAX_TOKENS=2000

# Optional per-scene LLM dialogue attribution (ambiguous multi-speaker scenes only)
# Recommended: true with batching — ~0–2 extra API calls per book
VAE_ATTR_LLM=true
VAE_ATTR_LLM_MAX_SCENES=8
VAE_ATTR_LLM_BATCH=5
# Expression Sensitivity Plan Phase 1d/1e: focused re-tag pass over dialogue
# lines only. Off = only auto-triggered when a chapter audits as suspiciously
# flat (recommended default). true = always run it. See docs/EXPRESSION_SENSITIVITY_PLAN.md.
# VAE_EXPRESSION_REPASS=true
# Parallel per-chapter imaging: generate art for a chapter's new characters/
# scenes on a separate queue (vae-imaging) as soon as it's checkpointed,
# instead of waiting for the whole book to finish extracting first. Off by
# default — new code path, and the fallback (today's sequential
# extract-everything-then-image-everything) is always safe either way. See
# docs/LOCAL_LLM_EXTRACTION.md's "Parallel per-chapter imaging" section.
# VAE_PARALLEL_IMAGING=true
# Simplest-form guard: cap chars sent in one mega-pass (0 = no cap).
GEMINI_MAX_CHARS=120000
# Illustration mode on ingest: auto | reference | moment | direct-use
# moment = flash inserts on dialogue lines + use plates for sprite-gen reference
ILLUSTRATION_MODE=auto

# ---- Edge neural voices (no key needed; server-side synthesis) ----
EDGE_TTS_VOICE=en-US-AndrewMultilingualNeural
EDGE_TTS_NARRATOR_M=en-US-AndrewMultilingualNeural
EDGE_TTS_NARRATOR_F=en-US-AvaMultilingualNeural

# ---- Server / storage ----
DATA_DIR=./data
API_HOST=0.0.0.0
API_PORT=8600
STOCK_POOL_SIZE=12
# Optional: co-host the built web client from FastAPI
# SERVE_WEB_DIST=./web/dist

# ---- Cloudflare R2 (offline pack cache mirror) ----
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=vae-packs

# ---- Cloudflare Queue consumer webhook (shared with portfolio Worker) ----
# QUEUE_WEBHOOK_SECRET=
