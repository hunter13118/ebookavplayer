# ---- Gemini (single mega-pass + image gen). Free tier via Google AI Studio. ----
GEMINI_API_KEY=
# Text mega-pass. Gemini 3.5 is current (2026); gemini-2.5-flash stays valid and
# is reliable for JSON mode. Try gemini-3.5-flash / gemini-flash-latest to upgrade.
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated fallback chains (tried in order on rate limit / quota errors).
GEMINI_TEXT_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash
GEMINI_IMAGE_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image,gemini-3-pro-image
# Retries per model on 429 / rate-limit before advancing the chain.
GEMINI_RETRY_COUNT=2
GEMINI_RETRY_BACKOFF_SEC=3
# Local SD via War Council battle-log (POST /images/generate on port 3737).
LOCAL_IMAGE_URL=http://127.0.0.1:3737/images/generate
LOCAL_IMAGE_TIMEOUT=300

# Free image APIs (server-side only — see IMAGE AND VOICE HANDOFF/)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# POLLINATIONS_TOKEN=
# HF_TOKEN=
# DISABLE_FREEMIUM_IMAGE=0

# Free LLM extract APIs (fallback when Gemini quota exhausted — freemiumExtract.js)
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# DISABLE_FREEMIUM_EXTRACT=0
# EXTRACT_FORCE_FREEMIUM=0
# EXTRACT_CHUNK_MAX_TOKENS=24000
# Simplest-form guard: cap chars sent in one mega-pass (0 = no cap).
GEMINI_MAX_CHARS=120000
# Illustration mode on ingest: auto | reference | moment | direct-use
# moment = flash inserts on dialogue lines + use plates for sprite-gen reference
ILLUSTRATION_MODE=auto

# ---- Edge neural voices (no key needed; server-side synthesis) ----
EDGE_TTS_VOICE=en-US-AndrewMultilingualNeural
EDGE_TTS_NARRATOR_M=en-US-AndrewMultilingualNeural
EDGE_TTS_NARRATOR_F=en-US-AvaMultilingualNeural

# ---- Server / storage ----
DATA_DIR=./data
API_HOST=0.0.0.0
API_PORT=8600
STOCK_POOL_SIZE=12
# Optional: co-host the built web client from FastAPI
# SERVE_WEB_DIST=./web/dist
